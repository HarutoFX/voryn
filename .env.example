# VORYN environment variables
# Copy this file to `.env.local` for local development.

# Backend API base URL used by the frontend.
VORYN_API_BASE_URL="http://localhost:8000"

# Optional local model endpoint for workspace features.
VORYN_MODEL_BASE_URL="http://localhost:11434"

# Optional model name used by the workspace.
VORYN_MODEL_NAME="llama3.2"
